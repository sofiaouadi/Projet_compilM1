PROGRAM Test
DECL
INTEGER: A;
INTEGER: B;
INTEGER: MAX;
INTEGER: i;
INTEGER: T[10];

FLOAT: X;
FLOAT: Y;

CONST PI = 3.14;
CONST LIMIT = 50;
ENDDECL

BEGIN

/* ===================== */
A = 5;
B = 10;
X = 2.5;
Y = 3.0;

/* ===================== IF */
IF (A > B) {
    MAX = A;
}
ELSE {
    MAX = B;
}

/* ===================== WHILE */
WHILE (A < 20) {
    A = A + 1;
}

/* ===================== FOR */
FOR (i: 0:1:5) {
    A = A + i;
}

/* ===================== TABLEAU */
T[0] = 10;
T[1] = 20;

/* ===================== IMBRICATION */
IF (A > 0) {
    WHILE (A < 30) {
        A = A + 1;
    }
}

/* ===================== FOR + IF + WHILE */
FOR (i: 0:1:3) {
    IF (i < 2) {
        WHILE (A < 50) {
            A = A + 1;
        }
    }
    ELSE {
        A = A + 10;
    }
}

/* ===================== WRITE */
WRITE(A);
WRITE(X);
WRITE(T[1]);

END